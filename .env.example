# Expo public environment variables (SDK 49+ — no extra packages needed).
# Copy this to .env and fill in for local (non-Docker) development.
# When running via Docker, docker-compose sets EXPO_PUBLIC_API_URL automatically.
#
# EXPO_PUBLIC_* variables are inlined by Metro at bundle time.
# They are safe to use in client-side code (do NOT put secrets here).
#
# Replace with your machine's LAN IP when testing on a physical device:
EXPO_PUBLIC_API_URL=http://localhost:8000
